# ── Telegram ───────────────────────────────────────────────
# Получить у @BotFather
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Telegram ID администратора (берётся из промпта)
ADMIN_ID=5453071067

# ── TonAPI (tonconsole.com) ────────────────────────────────
# Личный ключ обязателен для продакшена (без него жёсткие лимиты)
TONAPI_KEY=your-tonapi-key
TONAPI_BASE_URL=https://tonapi.io

# ── PostgreSQL ─────────────────────────────────────────────
# В docker-compose хост = "postgres". Локально без докера = "localhost".
DATABASE_URL=postgres://tracker:tracker@postgres:5432/tracker

# ── Прочее ─────────────────────────────────────────────────
LOG_LEVEL=info
# Период страхующего опроса всех кошельков, сек (на случай обрыва SSE)
SWEEP_INTERVAL_SEC=120
# Сколько кошельков проверять параллельно во время sweep/SSE-добора
WATCHER_CONCURRENCY=8
# Таймаут и ретраи REST-запросов к TonAPI
TONAPI_TIMEOUT_MS=10000
TONAPI_RETRIES=3
# Прикладывать свечной график к уведомлениям buy/sell/swap (true/false)
CHART_ENABLED=true
